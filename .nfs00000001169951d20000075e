#!/usr/bin/env bash
# Run NoisyDQN vs vanilla DQN on MiniGrid-DoorKey-6x6 sequentially.
#
# Usage:
#   chmod +x run_minigrid.sh
#   ./run_minigrid.sh
#
# Smoke test with fewer steps:
#   TOTAL_STEPS=20000 ./run_minigrid.sh
#
# Already-finished runs are skipped automatically (log.npz present).
# Each job writes to runs/<name>/:
#   train.log, rewards.png, sigma.png / epsilon.png, log.npz, model.pt

set -euo pipefail
cd "$(dirname "$0")"

# ---- 1. venv + deps (one-time) -------------------------------------------
if [ ! -d .venv ]; then
    echo "==> creating venv"
    python3 -m venv .venv
fi

PY=.venv/bin/python
$PY -m pip install --upgrade pip --quiet
$PY -m pip install -r requirements.txt --quiet
$PY -m pip install minigrid --quiet

mkdir -p runs
mkdir -p runs/.matplotlib
export MPLCONFIGDIR="$PWD/runs/.matplotlib"
export PYTHONUNBUFFERED=1

# ---- 2. knobs ------------------------------------------------------------
TOTAL_STEPS=${TOTAL_STEPS:-2000000}
ENV="MiniGrid-DoorKey-6x6-v0"

# ---- 3. helper -----------------------------------------------------------
run() {
    local name=$1; shift
    local outdir="runs/$name"
    mkdir -p "$outdir"

    if [ -f "$outdir/log.npz" ]; then
        echo "==> skipping $name (already done)"
        return
    fi

    echo
    echo "=========================================="
    echo "==> starting: $name"
    echo "=========================================="
    $PY train_minigrid.py \
        --env-id "$ENV" \
        --total-steps "$TOTAL_STEPS" \
        --out-dir "$outdir" \
        "$@" 2>&1 | tee "$outdir/train.log"
    echo "==> done: $name"
}

# ---- 4. jobs -------------------------------------------------------------
run doorkey_noisy
run doorkey_baseline  --no-noisy

echo
echo "==> All jobs finished. Generate plots with:"
echo "    .venv/bin/python plot_minigrid.py"
